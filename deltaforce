        const categories = [
            { id: 'operator', label: '👤 探員', data: operators, displayKey: 'name' },
            { id: 'vest', label: '🛡️ 防彈衣', data: vests, displayKey: 'name' },
            { id: 'helmet', label: '⛑️ 頭盔', data: helmets, displayKey: 'name' },
            { id: 'chest', label: '🦺 胸掛', data: chestRigs, displayKey: 'name' },
            { id: 'backpack', label: '🎒 背包', data: backpacks, displayKey: 'name' },
            { id: 'gun', label: '🔫 槍械', data: guns, displayKey: 'name' },
            { id: 'map', label: '🗺️ 地圖', data: maps, displayKey: 'name' }
        ];

        let selectedItems = {};

        function buildPoolUI() {
            let html = '';
            categories.forEach(cat => {
                const items = cat.data;
                html += `<div class="pool-section">`;
                html += `<div class="section-title">
                            ${cat.label}
                            <span class="toggle-all" data-category="${cat.id}">全選</span>
                            <span class="toggle-all" data-category="${cat.id}" data-action="none">取消全選</span>
                            <span style="font-size:0.65rem;color:#4a6a7a;margin-left:auto;">已選 <span class="selected-count" id="count-${cat.id}">${items.length}</span>/${items.length}</span>
                        </div>`;
                html += `<div class="pool-items" data-category="${cat.id}">`;
                items.forEach((item, index) => {
                    const id = `${cat.id}-${index}`;
                    const name = item.name || '未命名';
                    html += `<label>
                                <input type="checkbox" class="item-check" data-category="${cat.id}" data-index="${index}" checked>
                                ${name}
                            </label>`;
                });
                html += `</div></div>`;
            });
            poolContainer.innerHTML = html;

            categories.forEach(cat => {
                selectedItems[cat.id] = cat.data.slice();
            });

            document.querySelectorAll('.toggle-all').forEach(btn => {
                btn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const catId = this.dataset.category;
                    const action = this.dataset.action || 'select';
                    const checkboxes = document.querySelectorAll(`.item-check[data-category="${catId}"]`);
                    const checked = action === 'select';
                    checkboxes.forEach(cb => cb.checked = checked);
                    updateSelected(catId);
                    updateCount(catId);
                });
            });

            document.querySelectorAll('.item-check').forEach(cb => {
                cb.addEventListener('change', function() {
                    const catId = this.dataset.category;
                    updateSelected(catId);
                    updateCount(catId);
                });
            });

            categories.forEach(cat => updateCount(cat.id));
        }

        function updateSelected(catId) {
            const checkboxes = document.querySelectorAll(`.item-check[data-category="${catId}"]`);
            const cat = categories.find(c => c.id === catId);
            if (!cat) return;
            const selected = [];
            checkboxes.forEach((cb, idx) => {
                if (cb.checked) {
                    selected.push(cat.data[idx]);
                }
            });
            selectedItems[catId] = selected;
        }

        function updateCount(catId) {
            const count = selectedItems[catId] ? selectedItems[catId].length : 0;
            const total = categories.find(c => c.id === catId).data.length;
            const span = document.getElementById(`count-${catId}`);
            if (span) span.textContent = count;
        }

        buildPoolUI();

        // ============================================================
        // 6. 隨機生成 / 重置
        // ============================================================
        function randomize() {
            const anySelected = Object.values(selectedItems).some(arr => arr && arr.length > 0);
            if (!anySelected) {
                alert('請至少勾選一項裝備！');
                return;
            }
            const loadout = generateLoadout(selectedItems);
            equipmentDisplay.innerHTML = renderLoadout(loadout);
        }

        function resetDisplay() {
            equipmentDisplay.innerHTML = `<div class="empty-state">⚙️ 點擊「隨機生成」獲取一套裝備</div>`;
        }

        randomBtn.removeEventListener('click', randomize);
        randomBtn.addEventListener('click', randomize);
        resetBtn.removeEventListener('click', resetDisplay);
        resetBtn.addEventListener('click', resetDisplay);

        resetDisplay();

        // ============================================================
        // 7. 音樂書籤 — 使用內嵌播放器（無 sandbox 限制）
        // ============================================================
        const songLibrary = [
            // ===== 華語歌曲 =====
            { title: '孤勇者', artist: '陳奕迅', videoId: 'wkVhW1Fj7wA' },
            { title: '稻香', artist: '周杰倫', videoId: 'sHD7N2kAkUo' },
            { title: '光年之外', artist: '鄧紫棋', videoId: 'fZiO81b03kY' },
            { title: '說好不哭', artist: '周杰倫 ft. 五月天阿信', videoId: '5FkUhl-fVsk' },
            { title: '起風了', artist: '買辣椒也用券', videoId: 'jqwP9PzKdKY' },
            { title: '小幸運', artist: '田馥甄', videoId: 'QqD8ae2-LsA' },
            { title: '夜曲', artist: '周杰倫', videoId: 'lxEQRGJEGpk' },
            { title: '追光者', artist: '岑寧兒', videoId: '4ZxJh0Aw5VI' },
            { title: '說謊', artist: '林宥嘉', videoId: 'jP2rQ9dZ0Cg' },
            { title: '修煉愛情', artist: '林俊傑', videoId: '9h1yO6C5LqE' },
            // ===== 西洋歌曲 =====
            { title: 'Never Gonna Give You Up', artist: 'Rick Astley', videoId: 'dQw4w9WgXcQ' },
            { title: 'Shape of You', artist: 'Ed Sheeran', videoId: 'JGwWNGJdvx8' },
            { title: 'See You Again', artist: 'Wiz Khalifa ft. Charlie Puth', videoId: 'RgKAFK5djSk' },
            { title: 'Uptown Funk', artist: 'Mark Ronson ft. Bruno Mars', videoId: 'OPf0YbXqDm0' },
            { title: 'Gangnam Style', artist: 'PSY', videoId: '9bZkp7q19f0' },
            { title: 'Shake It Off', artist: 'Taylor Swift', videoId: 'nfWlot6h_JM' },
            { title: 'Believer', artist: 'Imagine Dragons', videoId: '7wtfhZwyrcc' },
            { title: 'Havana', artist: 'Camila Cabello ft. Young Thug', videoId: 'HCjNJDNzw8Y' },
            { title: 'Something Just Like This', artist: 'The Chainsmokers & Coldplay', videoId: 'FM7MFYoylVs' },
            { title: 'Closer', artist: 'The Chainsmokers ft. Halsey', videoId: 'PT2_F-1esPk' },
            { title: 'Starboy', artist: 'The Weeknd ft. Daft Punk', videoId: '34Na4j8AVgA' },
            { title: 'Lean On', artist: 'Major Lazer & DJ Snake ft. MØ', videoId: 'YqeW9_5kURI' },
            { title: 'Faded', artist: 'Alan Walker', videoId: '60ItHLz5WEA' },
            { title: 'Alone', artist: 'Marshmello', videoId: 'ALZHF5UqnU4' },
            { title: 'Beauty and a Beat', artist: 'Justin Bieber ft. Nicki Minaj', videoId: 'QpSqLC3m4vE' },
            { title: 'Night Dancer', artist: 'imase', videoId: '9Gj7lLmZn_Y' },
        ];

        // ============================================================
        // 8. 音樂功能 — 內嵌播放器
        // ============================================================
        const musicToggle = document.getElementById('musicToggle');
        const musicSidebar = document.getElementById('musicSidebar');
        const musicCloseBtn = document.getElementById('musicCloseBtn');
        const searchInput = document.getElementById('searchInput');
        const resultsArea = document.getElementById('resultsArea');
        const playerWrapper = document.getElementById('playerWrapper');
        const playerIframe = document.getElementById('playerIframe');

        let currentVideoId = null;

        function openSidebar() {
            musicSidebar.classList.add('open');
            renderResults(songLibrary);
            searchInput.value = '';
        }

        function closeSidebar() {
            musicSidebar.classList.remove('open');
            // 停止播放
            playerWrapper.classList.remove('active');
            playerIframe.src = '';
            currentVideoId = null;
        }

        musicToggle.addEventListener('click', openSidebar);
        musicCloseBtn.addEventListener('click', closeSidebar);

        function filterSongs() {
            const query = searchInput.value.trim().toLowerCase();
            if (!query) {
                renderResults(songLibrary);
                return;
            }
            const filtered = songLibrary.filter(item =>
                item.title.toLowerCase().includes(query) ||
                item.artist.toLowerCase().includes(query)
            );
            renderResults(filtered);
        }

        searchInput.addEventListener('input', filterSongs);

        function renderResults(items) {
            if (items.length === 0) {
                resultsArea.innerHTML = `<div class="no-results">😕 找不到相關內容</div>`;
                return;
            }
            let html = '';
            items.forEach(item => {
                html += `
                    <div class="result-item" data-videoid="${item.videoId}">
                        <div class="thumbnail">
                            <img src="https://img.youtube.com/vi/${item.videoId}/hqdefault.jpg" alt="${item.title}" loading="lazy" onerror="this.style.display='none'; this.parentElement.innerHTML='🎵'">
                        </div>
                        <div class="info">
                            <div class="title">${item.title}</div>
                            <div class="artist">${item.artist}</div>
                            <div class="play-hint">▶ 點擊播放</div>
                        </div>
                    </div>
                `;
            });
            resultsArea.innerHTML = html;

            // 點擊播放
            document.querySelectorAll('.result-item').forEach(el => {
                el.addEventListener('click', function() {
                    const videoId = this.dataset.videoid;
                    if (videoId && videoId.length > 5) {
                        playVideo(videoId);
                    }
                });
            });
        }

        function playVideo(videoId) {
            if (currentVideoId === videoId && playerWrapper.classList.contains('active')) {
                // 同一首歌，關閉播放器
                playerWrapper.classList.remove('active');
                playerIframe.src = '';
                currentVideoId = null;
                return;
            }
            // 使用標準嵌入方式（無 sandbox 限制）
            const embedUrl = `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0&enablejsapi=1`;
            playerIframe.src = embedUrl;
            playerWrapper.classList.add('active');
            currentVideoId = videoId;
            // 滾動到播放器
            playerWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // 點擊外部關閉
        document.addEventListener('click', function(e) {
            if (musicSidebar.classList.contains('open')) {
                const isInside = musicSidebar.contains(e.target);
                const isToggle = musicToggle.contains(e.target);
                if (!isInside && !isToggle) {
                    closeSidebar();
                }
            }
        });

        console.log('🎵 音樂書籤已載入，共 ' + songLibrary.length + ' 首歌曲');
        console.log('💰 貨幣：哈夫幣');
        console.log('💡 點擊歌曲即可在側邊欄內播放');
    </script>
</body>
