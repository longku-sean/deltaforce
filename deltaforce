<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>三角洲行動 · 精細隨機裝備 + 音樂書籤</title>
    <style>
        /* ===== 全局 ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            background: radial-gradient(ellipse at center, #1a2a2f, #0b1215);
            font-family: 'Segoe UI', 'PingFang TC', system-ui, sans-serif;
            color: #d0e0e8;
            min-height: 100vh;
            padding: 20px;
            padding-right: 70px;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background: rgba(20, 35, 42, 0.85);
            backdrop-filter: blur(4px);
            border-radius: 40px;
            padding: 30px 35px 40px;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.8), inset 0 1px 0 rgba(100, 180, 200, 0.08);
            border: 1px solid rgba(60, 140, 180, 0.12);
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 24px;
            border-bottom: 1px solid rgba(60, 140, 180, 0.08);
            padding-bottom: 18px;
        }
        .header h1 {
            font-weight: 300;
            font-size: 2.2rem;
            letter-spacing: 6px;
            color: #b8e6ff;
            text-shadow: 0 0 40px rgba(60, 180, 255, 0.06);
        }
        .header h1 span {
            color: #e8b830;
        }
        .header .badge {
            background: rgba(60, 140, 180, 0.12);
            border: 1px solid rgba(60, 140, 180, 0.1);
            border-radius: 60px;
            padding: 8px 22px;
            font-size: 0.85rem;
            color: #8ab8d0;
            letter-spacing: 1px;
        }
        .controls {
            display: flex;
            gap: 14px;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }
        .btn {
            background: rgba(40, 70, 85, 0.4);
            border: 1px solid rgba(60, 140, 180, 0.1);
            color: #c8dce8;
            padding: 10px 32px;
            border-radius: 60px;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            box-shadow: 0 4px 0 rgba(0, 0, 0, 0.25);
            transition: all 0.1s ease;
            letter-spacing: 1px;
            font-family: inherit;
        }
        .btn:hover {
            transform: translateY(-2px);
            background: rgba(60, 100, 120, 0.5);
            color: #fff;
        }
        .btn:active {
            transform: translateY(4px);
            box-shadow: 0 1px 0 rgba(0, 0, 0, 0.25);
        }
        .btn-primary {
            background: linear-gradient(145deg, #1a6a40, #0f4a2a);
            border-color: #3aaf7a;
            color: #d4ffe0;
            box-shadow: 0 4px 0 #0a2a18, 0 0 20px rgba(30, 150, 80, 0.06);
        }
        .btn-primary:hover {
            background: #2a8a5a;
        }
        .btn-secondary {
            background: rgba(50, 40, 60, 0.5);
            border-color: rgba(160, 140, 180, 0.15);
            color: #c8b8d8;
        }
        .btn-secondary:hover {
            background: rgba(70, 60, 80, 0.6);
        }

        /* ===== 獎池勾選區 ===== */
        .pool-section {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 20px;
            padding: 16px 20px;
            margin-bottom: 18px;
            border: 1px solid rgba(60, 140, 180, 0.06);
        }
        .pool-section .section-title {
            font-size: 0.9rem;
            font-weight: 500;
            color: #8ab8d0;
            letter-spacing: 1px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
        }
        .pool-section .section-title .toggle-all {
            font-size: 0.7rem;
            background: rgba(60, 140, 180, 0.1);
            border: 1px solid rgba(60, 140, 180, 0.1);
            border-radius: 30px;
            padding: 2px 14px;
            cursor: pointer;
            color: #7a9aaa;
            transition: 0.1s;
        }
        .pool-section .section-title .toggle-all:hover {
            background: rgba(60, 140, 180, 0.2);
            color: #b0d8e8;
        }
        .pool-items {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 16px;
        }
        .pool-items label {
            display: flex;
            align-items: center;
            gap: 5px;
            font-size: 0.8rem;
            color: #b0c8d8;
            cursor: pointer;
            transition: 0.1s;
        }
        .pool-items label:hover {
            color: #d0e8f0;
        }
        .pool-items input[type="checkbox"] {
            width: 14px;
            height: 14px;
            accent-color: #5ab08a;
            cursor: pointer;
        }
        .pool-items .item-count {
            font-size: 0.65rem;
            color: #4a6a7a;
            margin-left: 2px;
        }

        /* ===== 裝備展示 ===== */
        .equipment-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 10px;
        }
        .equip-card {
            background: rgba(12, 26, 34, 0.6);
            border: 1px solid rgba(60, 140, 180, 0.06);
            border-radius: 20px;
            padding: 16px 18px 18px;
            backdrop-filter: blur(2px);
            transition: 0.15s;
            box-shadow: inset 0 0 0 1px rgba(60, 140, 180, 0.02);
            position: relative;
        }
        .equip-card:hover {
            border-color: rgba(60, 180, 220, 0.15);
        }
        .equip-card .category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #5a8a9a;
            border-bottom: 1px solid rgba(60, 140, 180, 0.06);
            padding-bottom: 8px;
            margin-bottom: 12px;
        }
        .equip-card .item-name {
            font-size: 1.1rem;
            font-weight: 400;
            color: #d0e8f0;
            line-height: 1.4;
        }
        .equip-card .item-detail {
            font-size: 0.8rem;
            color: #7a9aaa;
            margin-top: 6px;
            line-height: 1.5;
        }
        .equip-card .item-detail strong {
            color: #a0c8d8;
            font-weight: 400;
        }
        .equip-card .value-tag {
            position: absolute;
            top: 12px;
            right: 14px;
            background: rgba(232, 184, 48, 0.12);
            border: 1px solid rgba(232, 184, 48, 0.15);
            border-radius: 30px;
            padding: 2px 12px;
            font-size: 0.7rem;
            color: #e8b830;
            letter-spacing: 0.5px;
        }
        .role-tag {
            display: inline-block;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 2px 10px;
            border-radius: 30px;
            margin-top: 4px;
        }
        .role-tag.assault {
            background: rgba(200, 60, 60, 0.2);
            border: 1px solid rgba(200, 60, 60, 0.2);
            color: #ff8a8a;
        }
        .role-tag.medical {
            background: rgba(60, 200, 100, 0.2);
            border: 1px solid rgba(60, 200, 100, 0.2);
            color: #7ae8a0;
        }
        .role-tag.engineer {
            background: rgba(60, 160, 200, 0.2);
            border: 1px solid rgba(60, 160, 200, 0.2);
            color: #7ac8e8;
        }
        .role-tag.scout {
            background: rgba(200, 180, 60, 0.2);
            border: 1px solid rgba(200, 180, 60, 0.2);
            color: #e8d87a;
        }
        .ammo-box {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 12px;
            padding: 8px 12px;
            margin-top: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid #e8b830;
        }
        .ammo-box .caliber {
            font-size: 0.75rem;
            color: #6a8a9a;
        }
        .ammo-box .count {
            font-weight: 500;
            color: #d4e8f0;
        }
        .attachment-list {
            display: flex;
            flex-wrap: wrap;
            gap: 6px 10px;
            margin-top: 8px;
        }
        .attachment-tag {
            background: rgba(40, 70, 85, 0.3);
            border-radius: 30px;
            padding: 2px 12px;
            font-size: 0.7rem;
            color: #8ab8d0;
            border: 1px solid rgba(60, 140, 180, 0.06);
        }
        .attachment-tag .cat {
            color: #5a8a9a;
        }
        .attachment-tag .val {
            color: #c0dce8;
        }
        .meds-list {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-top: 6px;
        }
        .med-tag {
            background: rgba(180, 60, 60, 0.15);
            border: 1px solid rgba(200, 80, 80, 0.1);
            border-radius: 30px;
            padding: 2px 14px;
            font-size: 0.75rem;
            color: #e8b0b0;
        }
        .map-tier {
            display: inline-block;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 2px 10px;
            border-radius: 30px;
            margin-top: 4px;
        }
        .map-tier.tier-secret {
            background: rgba(60, 140, 200, 0.15);
            border: 1px solid rgba(60, 140, 200, 0.15);
            color: #7ac8e8;
        }
        .map-tier.tier-topsecret {
            background: rgba(200, 60, 60, 0.2);
            border: 1px solid rgba(200, 60, 60, 0.2);
            color: #ff8a8a;
        }
        .total-value-card {
            grid-column: 1 / -1;
            background: rgba(232, 184, 48, 0.06);
            border: 1px solid rgba(232, 184, 48, 0.12);
            border-radius: 20px;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 6px;
        }
        .total-value-card .label {
            font-size: 0.9rem;
            color: #8ab8d0;
            letter-spacing: 1px;
        }
        .total-value-card .value {
            font-size: 1.8rem;
            font-weight: 300;
            color: #e8b830;
            text-shadow: 0 0 30px rgba(232, 184, 48, 0.08);
        }
        .total-value-card .value span {
            font-size: 1rem;
            color: #6a8a9a;
            margin-left: 6px;
        }
        .empty-state {
            text-align: center;
            padding: 50px 20px;
            color: #4a6a7a;
            font-size: 1.1rem;
            letter-spacing: 2px;
        }

        /* ===== 音樂書籤 ===== */
        .music-toggle {
            position: fixed;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            z-index: 999;
            background: rgba(20, 40, 55, 0.8);
            backdrop-filter: blur(6px);
            border: 1px solid rgba(60, 140, 180, 0.2);
            border-right: none;
            border-radius: 30px 0 0 30px;
            padding: 14px 10px 14px 14px;
            cursor: pointer;
            transition: all 0.25s ease;
            box-shadow: -4px 0 20px rgba(0, 0, 0, 0.4);
            color: #b8e6ff;
            font-size: 1.6rem;
            writing-mode: vertical-rl;
            letter-spacing: 4px;
            user-select: none;
        }
        .music-toggle:hover {
            background: rgba(30, 60, 80, 0.9);
            padding-right: 16px;
            color: #fff;
            box-shadow: -6px 0 30px rgba(0, 0, 0, 0.6);
        }
        .music-toggle .icon {
            display: inline-block;
            font-size: 1.8rem;
            writing-mode: horizontal-tb;
            margin-bottom: 6px;
        }
        .music-sidebar {
            position: fixed;
            top: 0;
            right: -500px;
            width: 480px;
            height: 100vh;
            background: rgba(12, 24, 34, 0.96);
            backdrop-filter: blur(12px);
            border-left: 1px solid rgba(60, 140, 180, 0.15);
            box-shadow: -10px 0 50px rgba(0, 0, 0, 0.7);
            z-index: 1000;
            transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            padding: 20px 18px;
            font-family: 'Segoe UI', 'PingFang TC', system-ui, sans-serif;
            color: #d0e0e8;
        }
        .music-sidebar.open {
            right: 0;
        }
        .music-sidebar .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(60, 140, 180, 0.06);
            margin-bottom: 16px;
            flex-wrap: nowrap;
        }
        .music-sidebar .header h2 {
            font-weight: 300;
            font-size: 1.3rem;
            letter-spacing: 3px;
            color: #b8e6ff;
        }
        .music-sidebar .close-btn {
            background: none;
            border: none;
            color: #6a8a9a;
            font-size: 1.8rem;
            cursor: pointer;
            transition: 0.15s;
            padding: 0 6px;
        }
        .music-sidebar .close-btn:hover {
            color: #ff6b6b;
            transform: rotate(90deg);
        }
        .search-area {
            display: flex;
            gap: 10px;
            margin-bottom: 18px;
        }
        .search-area input {
            flex: 1;
            padding: 10px 16px;
            border-radius: 60px;
            border: 1px solid rgba(60, 140, 180, 0.1);
            background: rgba(0, 0, 0, 0.3);
            color: #d0e8f0;
            font-size: 0.95rem;
            outline: none;
            transition: 0.15s;
        }
        .search-area input:focus {
            border-color: rgba(60, 180, 220, 0.3);
            background: rgba(0, 0, 0, 0.5);
        }
        .search-area input::placeholder {
            color: #4a6a7a;
        }
        .results-area {
            flex: 1;
            overflow-y: auto;
            padding-right: 4px;
        }
        .results-area::-webkit-scrollbar {
            width: 4px;
        }
        .results-area::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.2);
            border-radius: 4px;
        }
        .results-area::-webkit-scrollbar-thumb {
            background: #2a5a6a;
            border-radius: 4px;
        }
        .result-item {
            display: flex;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 16px;
            background: rgba(20, 40, 55, 0.3);
            border: 1px solid rgba(60, 140, 180, 0.04);
            margin-bottom: 10px;
            cursor: pointer;
            transition: 0.15s;
            align-items: center;
        }
        .result-item:hover {
            background: rgba(30, 60, 80, 0.4);
            border-color: rgba(60, 180, 220, 0.15);
            transform: scale(1.01);
        }
        .result-item .thumbnail {
            width: 80px;
            height: 56px;
            border-radius: 10px;
            background: #1a2a2f;
            flex-shrink: 0;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: #4a7a8a;
            border: 1px solid rgba(60, 140, 180, 0.06);
        }
        .result-item .thumbnail img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .result-item .info {
            flex: 1;
            min-width: 0;
        }
        .result-item .info .title {
            font-size: 0.95rem;
            font-weight: 400;
            color: #d0e8f0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .result-item .info .artist {
            font-size: 0.75rem;
            color: #6a8a9a;
            margin-top: 2px;
        }
        .result-item .info .play-hint {
            font-size: 0.65rem;
            color: #5ab08a;
            margin-top: 2px;
        }

        /* ===== 播放器 ===== */
        .player-wrapper {
            margin-top: 16px;
            border-radius: 16px;
            overflow: hidden;
            background: #0a1a22;
            border: 1px solid rgba(60, 140, 180, 0.06);
            display: none;
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
        }
        .player-wrapper.active {
            display: block;
        }
        .player-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: none;
        }

        .no-results {
            text-align: center;
            color: #4a6a7a;
            padding: 30px 0;
            font-size: 0.95rem;
            letter-spacing: 1px;
        }

        /* 響應式 */
        @media (max-width: 700px) {
            .container {
                padding: 20px 18px 25px;
            }
            .header h1 {
                font-size: 1.6rem;
                letter-spacing: 3px;
            }
            .equipment-grid {
                grid-template-columns: 1fr 1fr;
            }
            .btn {
                padding: 8px 20px;
                font-size: 0.85rem;
            }
            .music-sidebar {
                width: 360px;
                right: -380px;
            }
            .music-toggle {
                font-size: 1.2rem;
                padding: 10px 6px 10px 10px;
            }
            .music-toggle .icon {
                font-size: 1.4rem;
            }
            .result-item .thumbnail {
                width: 60px;
                height: 42px;
            }
        }
        @media (max-width: 480px) {
            .equipment-grid {
                grid-template-columns: 1fr;
            }
            .music-sidebar {
                width: 300px;
                right: -320px;
                padding: 14px 12px;
            }
            .search-area input {
                font-size: 0.85rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>⚡ 三角洲 · <span>精細</span>裝備</h1>
            <span class="badge">🎯 每項獨立勾選</span>
        </div>

        <div class="controls">
            <button class="btn btn-primary" id="randomBtn">🎲 隨機生成</button>
            <button class="btn btn-secondary" id="resetBtn">⟳ 重置</button>
        </div>

        <!-- 獎池勾選區 -->
        <div id="poolContainer"></div>

        <div id="equipmentDisplay">
            <div class="empty-state">⚙️ 點擊「隨機生成」獲取一套裝備</div>
        </div>
    </div>

    <!-- 音樂書籤 -->
    <div class="music-toggle" id="musicToggle">
        <span class="icon">🎵</span>音樂書籤
    </div>
    <div class="music-sidebar" id="musicSidebar">
        <div class="header">
            <h2>🎵 音樂書籤</h2>
            <button class="close-btn" id="musicCloseBtn">✕</button>
        </div>
        <div class="search-area">
            <input type="text" id="searchInput" placeholder="搜尋歌曲、藝人..." />
        </div>
        <div class="results-area" id="resultsArea">
            <div class="no-results">🔍 輸入關鍵字搜尋</div>
        </div>
        <div class="player-wrapper" id="playerWrapper">
            <iframe id="playerIframe" src="" allowfullscreen></iframe>
        </div>
    </div>

    <script>
        // ============================================================
        // 1. 裝備資料庫（完整）
        // ============================================================

        const operators = [
            { name: '紅狼', role: '突擊', ability: '戰術衝鋒 · 提升移動速度與近戰傷害' },
            { name: '威龍', role: '突擊', ability: '火力壓制 · 短時間內提升射速' },
            { name: '無名', role: '突擊', ability: '潛行突襲 · 隱蔽接近敵人' },
            { name: '疾風', role: '突擊', ability: '快速突進 · 衝刺後短暫提升攻擊力' },
            { name: '蜂醫', role: '醫療', ability: '醫療支援 · 快速治療隊友並恢復血量' },
            { name: '蠱', role: '醫療', ability: '毒素治療 · 使用特殊藥劑持續回血' },
            { name: '蝶', role: '醫療', ability: '快速救援 · 大幅縮短救治時間' },
            { name: '老黑', role: '工程', ability: '戰術指揮 · 提升團隊防禦力' },
            { name: '烏魯魯', role: '工程', ability: '防禦工事 · 建立臨時掩體' },
            { name: '比特', role: '工程', ability: '電子干擾 · 癱瘓敵方設備' },
            { name: '盾哥', role: '工程', ability: '重型防護 · 裝備盾牌抵擋正面攻擊' },
            { name: '液氮', role: '工程', ability: '冷凍陷阱 · 減速並凍結敵人' },
            { name: '露娜', role: '探測', ability: '偵查追蹤 · 標記隱藏敵人的位置' },
            { name: '麥曉雯', role: '探測', ability: '情報分析 · 顯示敵方弱點' },
            { name: '銀翼', role: '探測', ability: '無人偵查 · 釋放小型偵查無人機' },
            { name: '回響', role: '探測', ability: '聲波探測 · 發現周圍所有動靜' },
        ];

        const vests = [
            { name: '輕量防彈背心', level: 'II級', weight: '2.8kg' },
            { name: '戰術防彈背心', level: 'III級', weight: '4.0kg' },
            { name: '重型防彈背心', level: 'IV級', weight: '5.6kg' },
            { name: '特種作戰背心', level: 'III+級', weight: '4.4kg' },
            { name: '陶瓷複合防彈衣', level: 'V級', weight: '6.4kg' },
            { name: '輕量陶瓷背心', level: 'III級', weight: '3.2kg' },
        ];

        const helmets = [
            { name: '輕量化頭盔', level: 'II級', weight: '1.2kg' },
            { name: '戰術頭盔', level: 'III級', weight: '1.8kg' },
