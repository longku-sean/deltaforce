        function randomItem(arr) {
            return arr[Math.floor(Math.random() * arr.length)];
        }

        function randomInt(min, max) {
            return Math.floor(Math.random() * (max - min + 1)) + min;
        }

        function randomMulti(arr, n) {
            const result = [];
            for (let i = 0; i < n; i++) {
                result.push(randomItem(arr));
            }
            return result;
        }

        function getValueRange(category) {
            const ranges = {
                operator: [30000, 80000],
                vest: [50000, 150000],
                helmet: [20000, 80000],
                chest: [20000, 60000],
                backpack: [15000, 50000],
                gun: [100000, 300000],
                attachment: [10000, 50000],
                ammo: [5000, 20000],
                med: [3000, 15000],
                map: [0, 0]
            };
            return ranges[category] || [0, 0];
        }

        function randomValue(category) {
            const [min, max] = getValueRange(category);
            return randomInt(min, max);
        }

        // ============================================================
        // 3. 生成裝備
        // ============================================================
        function generateLoadout(selectedItems) {
            const result = {
                operator: null,
                vest: null,
                helmet: null,
                chest: null,
                backpack: null,
                gun: null,
                attachments: [],
                bullet: null,
                meds: [],
                map: null,
                totalValue: 0,
                items: []
            };
            let totalValue = 0;

            function pickOne(list, cat) {
                if (!list || list.length === 0) return null;
                const item = randomItem(list);
                const val = randomValue(cat);
                const fullItem = { ...item, value: val };
                totalValue += val;
                result.items.push({ category: cat, name: item.name || '未知', value: val });
                return fullItem;
            }

            if (selectedItems.operator && selectedItems.operator.length > 0) {
                result.operator = pickOne(selectedItems.operator, 'operator');
            }
            if (selectedItems.vest && selectedItems.vest.length > 0) {
                result.vest = pickOne(selectedItems.vest, 'vest');
            }
            if (selectedItems.helmet && selectedItems.helmet.length > 0) {
                result.helmet = pickOne(selectedItems.helmet, 'helmet');
            }
            if (selectedItems.chest && selectedItems.chest.length > 0) {
                result.chest = pickOne(selectedItems.chest, 'chest');
            }
            if (selectedItems.backpack && selectedItems.backpack.length > 0) {
                result.backpack = pickOne(selectedItems.backpack, 'backpack');
            }

            if (selectedItems.gun && selectedItems.gun.length > 0) {
                const gun = randomItem(selectedItems.gun);
                const gunVal = randomValue('gun');
                result.gun = { ...gun, value: gunVal };
                totalValue += gunVal;
                result.items.push({ category: '槍械', name: gun.name, value: gunVal });

                const attachCats = getAttachmentsForGun(gun);
                const selectedAttachments = attachCats.map(cat => {
                    const choice = randomItem(cat.options);
                    const val = randomValue('attachment');
                    totalValue += val;
                    result.items.push({ category: '配件-' + cat.category, name: choice, value: val });
                    return { category: cat.category, choice: choice, value: val };
                });
                result.attachments = selectedAttachments;

                const caliber = gun.caliber;
                const ammoList = ammoPool[caliber] || ['普通彈'];
                const bullet = randomItem(ammoList);
                const count = randomInt(60, 150);
                const ammoVal = randomValue('ammo');
                totalValue += ammoVal;
                result.bullet = { name: bullet, caliber: caliber, count: count, value: ammoVal };
                result.items.push({ category: '彈藥', name: bullet + ' x' + count, value: ammoVal });
            }

            const medCount = randomInt(2, 4);
            const selectedMeds = randomMulti(meds, medCount);
            result.meds = selectedMeds.map(m => {
                const val = randomValue('med');
                totalValue += val;
                result.items.push({ category: '藥品', name: m.name, value: val });
                return { ...m, value: val };
            });

            if (selectedItems.map && selectedItems.map.length > 0) {
                result.map = pickOne(selectedItems.map, 'map');
            }

            result.totalValue = totalValue;
            return result;
        }

